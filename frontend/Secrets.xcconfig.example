// Secrets.xcconfig.example — template (safe to commit)
//
// Setup:
//   1. Copy this file to `Secrets.xcconfig` (same folder). That copy is
//      git-ignored and is where your real values live.
//   2. Fill in your Supabase anon (publishable) key below.
//
// The value is injected into the generated Info.plist at build time and read
// at runtime in SupabaseClient.swift. Only the anon/publishable key belongs
// here — never the service_role key.

SUPABASE_ANON_KEY = your-supabase-anon-key
