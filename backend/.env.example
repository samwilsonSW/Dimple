# Dimple Backend Configuration
# Copy this file to .env and fill in your values

# ============================================
# SUPABASE (Required)
# ============================================
# Get these from your Supabase project dashboard:
# Project Settings > API > Project URL
SUPABASE_URL=https://your-project.supabase.co

# Project Settings > API > Project API Keys > service_role key (NOT anon key)
# This is secret — never expose it to the frontend
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# APPLICATION
# ============================================
# Environment: development | staging | production
ENVIRONMENT=development

# Secret key for JWT token validation (generate a random string)
# Used to sign/verify tokens if you roll your own auth
# Generate: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production

# CORS — comma-separated list of allowed origins
# For development, include your frontend dev server
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# ============================================
# OPTIONAL: LLM / RAG (for future use)
# ============================================
# OpenAI API key for embeddings and LLM analysis
# OPENAI_API_KEY=sk-...

# Anthropic API key for Claude-based analysis
# ANTHROPIC_API_KEY=sk-ant-...

# Embedding model to use
# EMBEDDING_MODEL=text-embedding-3-small
